# 【生产环境】配置文件模板
# Production Environment Configuration Template
#
# ⚠️ 使用说明：
# 1. 复制此文件为 .env.production
# 2. 修改所有标记为【必须修改】的配置项
# 3. 生成强随机密钥：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ==================== 服务器配置 ====================
NODE_ENV=production
PORT=3006

# ==================== 数据库配置 ====================
# 【必须修改】使用宝塔面板创建的数据库信息
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tool_isww_cn
DB_USER=tool_isww_cn
DB_PASSWORD=【必须修改】填写你的数据库密码

# ==================== JWT 配置 ====================
# 【必须修改】生成强随机密钥，至少64位
# 生成方法：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=【必须修改】生成64位随机密钥
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=【必须修改】生成64位随机密钥
JWT_REFRESH_EXPIRES_IN=7d

# ==================== 文件上传配置 ====================
# 【重要】必须使用绝对路径，确保文件保存到正确位置
UPLOAD_PATH=/www/wwwroot/toolbox/backend/uploads
MAX_FILE_SIZE=5242880

# ==================== CORS 配置 ====================
# 【必须修改】设置为你的前端域名
# 单个域名：CORS_ORIGIN=https://yourdomain.com
# 多个域名：CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=https://tool.isww.cn
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_CREDENTIALS=true
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_EXPOSED_HEADERS=Content-Range,X-Content-Range
CORS_MAX_AGE=86400

# ==================== 请求体限制 ====================
BODY_LIMIT_JSON=1mb
BODY_LIMIT_URLENCODED=1mb
BODY_LIMIT_RAW=5mb
BODY_LIMIT_TEXT=1mb

# ==================== 速率限制 ====================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_DIR=logs

# ==================== 安全配置 ====================
SECURITY_HELMET=true
TRUST_PROXY=true

# ==================== 管理员默认密码 ====================
# ⚠️ 仅用于初始化，部署后请立即修改
# ADMIN_DEFAULT_PASSWORD=your_secure_admin_password_here

# ==================== PDF/Office 转换 ====================
CONVERSION_UPLOAD_PATH=uploads/conversion-input
CONVERSION_OUTPUT_PATH=uploads/conversions
CONVERSION_MAX_FILE_SIZE=52428800
LIBREOFFICE_PATH=
OFFICE_CONVERT_TIMEOUT_MS=120000

# ==================== 外部工具路径（可选，默认使用 PATH 查找） ====================
# 如果 Python/FFmpeg 不在系统 PATH 中，请指定完整路径
# TOOL_PYTHON_PATH=python
# TOOL_FFMPEG_PATH=ffmpeg
