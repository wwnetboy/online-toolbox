# Server Configuration
NODE_ENV=development
PORT=3100

# Database Configuration
# ⚠️ 安全提示: 生产环境请使用强密码，至少16位，包含大小写字母、数字和特殊字符
DB_HOST=localhost
DB_PORT=3306
DB_NAME=toolbox
DB_USER=root
DB_PASSWORD=your_strong_password_here

# JWT Configuration
# ⚠️ 安全提示: 生产环境必须使用强随机密钥
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_generate_with_crypto
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_refresh_secret_key_here_generate_with_crypto
JWT_REFRESH_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880

# CORS Configuration (Requirement: 11.4)
# Comma-separated list of allowed origins, or * for all
CORS_ORIGIN=http://localhost:3010,http://localhost:3100
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_CREDENTIALS=true
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_EXPOSED_HEADERS=Content-Range,X-Content-Range
CORS_MAX_AGE=86400

# Request Body Limits (Requirement: 11.7)
BODY_LIMIT_JSON=1mb
BODY_LIMIT_URLENCODED=1mb
BODY_LIMIT_RAW=5mb
BODY_LIMIT_TEXT=1mb

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Security
SECURITY_HELMET=true
TRUST_PROXY=false

# Seed Script Configuration
# ⚠️ 安全提示: 仅用于初始化，生产环境部署后请立即修改所有默认密码
# ADMIN_DEFAULT_PASSWORD=your_secure_password_here

# PDF/Office 转换
CONVERSION_UPLOAD_PATH=uploads/conversion-input
CONVERSION_OUTPUT_PATH=uploads/conversions
CONVERSION_MAX_FILE_SIZE=52428800
LIBREOFFICE_PATH=
OFFICE_CONVERT_TIMEOUT_MS=120000

# 外部工具路径（可选，默认使用 PATH 查找）
# TOOL_PYTHON_PATH=python
# TOOL_FFMPEG_PATH=ffmpeg
